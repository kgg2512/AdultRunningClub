{
  "name": "arc-running-society",
  "version": "1.0.0",
  "description": "ARC — Running Society. Seoul's premier luxury running members club.",
  "private": true,
  "scripts": {
    "sync": "cp index.html www/index.html && echo 'www/index.html synced'",
    "build": "npm run sync && npx cap sync android",
    "build:android:release": "npm run build && cd android && ./gradlew bundleRelease",
    "build:android:debug": "npm run build && cd android && ./gradlew bundleDebug",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:update": "npx cap update"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/geolocation": "^6.0.2",
    "@capacitor/haptics": "^6.0.2",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/local-notifications": "^6.1.0",
    "@capacitor/push-notifications": "^6.0.2",
    "@capacitor/status-bar": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0"
  }
}
